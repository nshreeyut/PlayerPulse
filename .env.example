# PlayerPulse — Environment Variables
# Copy this file to .env and fill in your API keys

# ------------------------------------------------------------------
# Game Data APIs
# ------------------------------------------------------------------

# Steam Web API key — https://steamcommunity.com/dev/apikey
STEAM_API_KEY=

# RAWG.io API key — https://rawg.io/apidocs
RAWG_API_KEY=

# Riot Games API key — https://developer.riotgames.com (dev key, 24h validity)
# Covers: League of Legends, Valorant, TFT under one key
# Default region: na1 — set via RiotLoLCollector(region="euw1") etc.
RIOT_API_KEY=

# OpenDota — no key required

# ------------------------------------------------------------------
# LLM Provider
# ------------------------------------------------------------------
# Set LLM_PROVIDER to any supported provider. Only that provider's
# API key needs to be filled in. LLM_MODEL is optional — each
# provider has a sensible default if you leave it blank.
#
#   Provider    | Default model                    | Free tier?
#   ------------|----------------------------------|------------
#   groq        | llama-3.3-70b-versatile          | Yes (generous)
#   openai      | gpt-4o-mini                      | No
#   anthropic   | claude-3-5-haiku-20241022         | No
#   gemini      | gemini-2.0-flash                 | Yes (limited)
#   mistral     | mistral-small-latest             | No
#   nvidia      | nvidia/llama-3.1-nemotron-70b-instruct | Yes (build.nvidia.com)
#   ollama      | llama3.2                         | Local / free

LLM_PROVIDER=nvidia
LLM_MODEL=

# ------------------------------------------------------------------
# LLM API Keys — fill in the one matching LLM_PROVIDER
# ------------------------------------------------------------------

# Groq — https://console.groq.com
GROQ_API_KEY=

# OpenAI — https://platform.openai.com/api-keys
OPENAI_API_KEY=

# Anthropic — https://console.anthropic.com
ANTHROPIC_API_KEY=

# Google Gemini — https://aistudio.google.com/app/apikey
GOOGLE_API_KEY=

# Mistral — https://console.mistral.ai
MISTRAL_API_KEY=

# NVIDIA NIM — https://build.nvidia.com (free credits on sign-up)
# Key format: nvapi-xxxx
# Other Nemotron models: nvidia/llama-3.3-nemotron-super-49b-v1
#                        nvidia/nemotron-4-340b-instruct
NVIDIA_API_KEY=
# NVIDIA_BASE_URL=https://integrate.api.nvidia.com/v1

# Ollama (local) — no key needed. Adjust base URL if not on default port.
# Install: https://ollama.com  |  then: ollama pull llama3.2
# OLLAMA_BASE_URL=http://localhost:11434

# ------------------------------------------------------------------
# Pipeline Settings
# ------------------------------------------------------------------
# PLAYERPULSE_CHURN_THRESHOLD_DAYS=14
